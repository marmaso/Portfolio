# .gitignore para el portfolio (proyecto estático)
# Ignorar archivos/dirs generados por el sistema operativo
# Windows
Thumbs.db
Desktop.ini
ehthumbs.db

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Archivos de log
*.log

# Node / package managers (por si se usan herramientas locales)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build / cache outputs
dist/
build/
.cache/
.parcel-cache/
public/build/
coverage/

# Environment files (pueden contener secretos)
.env
.env.*.local

# IDE / editor
.vscode/
.idea/
*.iml
.Rider/

# Visual Studio / Rider / other IDE artifacts
*.suo
*.user
*.userosscache
*.sln
*.csproj.user

# Otros
Thumbs.db

# Si necesitas incluir paquetes lock o archivos de configuración específicos,
# quita la línea correspondiente.
